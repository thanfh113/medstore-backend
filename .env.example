# Auth
JWT_SECRET=medstore-super-secret-key-change-in-production
JWT_ISSUER=medstore-backend
JWT_AUDIENCE=medstore-clients
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# Database
DB_URL=jdbc:mysql://localhost:3306/medical_supplies_db?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true&characterEncoding=utf8mb4&useUnicode=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USER=root
DB_PASSWORD=

# Cloudinary
CLOUDINARY_CLOUD_NAME=root
CLOUDINARY_API_KEY=your-cloudiary-api-key
CLOUDINARY_API_SECRET=your-cloudiary-api-secret-key
CLOUDINARY_FOLDER_PREFIX=medstore



# Local uploads
# PDF certificates and banners are stored under LOCAL_UPLOAD_DIR and served from /static/uploads.
# Set LOCAL_PUBLIC_BASE_URL to the LAN/ngrok URL that Android devices can reach.
LOCAL_UPLOAD_DIR=uploads
LOCAL_PUBLIC_BASE_URL=http://192.168.1.10:8080

# Payment environment
PAYMENT_ENV=uat
PAYMENT_PUBLIC_BASE_URL=https://your-public-host.example.com
POS_PAYMENT_RETURN_URL=https://your-public-host.example.com/api/v1/payments/pos-return

# VNPay
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=6KXHBVDD
VNPAY_SECRET_KEY=RKQDKIJ6SRH4WP6HK8LT0ISCHAEF3P3W

# MoMo UAT Configuration
MOMO_PAYMENT_URL=https://uat.momo.vn/web/index.html
MOMO_CREATE_URL=https://uat.momo.vn/v2/gateway/api/create
MOMO_ACCESS_KEY=your-momo-uat-access-key
MOMO_PARTNER_CODE=your-momo-uat-partner-code
MOMO_SECRET_KEY=your-momo-uat-secret-key
MOMO_IPN_URL=https://your-public-host.example.com/api/v1/webhooks/momo/callback

# ZaloPay Credentials (Production)
ZALO_APP_ID=your-zalo-app-id
ZALO_KEY1=your-zalo-key1
ZALO_KEY2=your-zalo-key2

# Endpoint - Production
ZALO_ENDPOINT=https://api.zalopay.vn/v2/create
